{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-hide",
    {
      "identifier": "http:default",
      "allow": [{ "url": "https://api.github.com/**" }]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "gh",
          "cmd": "gh",
          "args": ["auth", "token"],
          "sidecar": false
        }
      ]
    },
    "shell:allow-open"
  ]
}
